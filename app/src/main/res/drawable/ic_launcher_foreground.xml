<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Tout le dessin est réduit à 80% autour du centre (54,54) pour rester
        dans la "safe zone" des adaptive icons (le masque rogne les bords).
    -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.8"
        android:scaleY="0.8">

        <!-- Piste de la jauge (blanc 20%) -->
        <path
            android:pathData="M26.3,70 A32,32 0 1,1 81.7,70"
            android:strokeColor="#33FFFFFF"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <!-- Progression (~70%) -->
        <path
            android:pathData="M26.3,70 A32,32 0 0,1 77.8,32.6"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="6"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <!-- Pastille à l'extrémité de la progression -->
        <path
            android:pathData="M77.8,32.6 m-4.5,0 a4.5,4.5 0 1,0 9,0 a4.5,4.5 0 1,0 -9,0"
            android:fillColor="#FFFFFFFF" />

        <!-- Symbole € : arc C ouvert à droite -->
        <path
            android:pathData="M64.4,48 A12,12 0 1,0 64.4,60"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="5"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <!-- Barre supérieure du € -->
        <path
            android:pathData="M41,50 H64"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="4.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

        <!-- Barre inférieure du € -->
        <path
            android:pathData="M41,57 H64"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="4.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000" />

    </group>
</vector>
