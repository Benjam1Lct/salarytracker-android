<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/w_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg"
    android:padding="18dp"
    android:baselineAligned="false">

    <!-- Bloc salaire -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.4"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/w_job"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#8B7CF6"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="NET DU MOIS"
            android:textColor="#9A95A6"
            android:textSize="11sp"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/w_net"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 €"
            android:textColor="#F4F2F8"
            android:textSize="30sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/w_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="16dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress" />

        <TextView
            android:id="@+id/w_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Objectif 0 €"
            android:textColor="#9A95A6"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="14dp"
        android:layout_marginVertical="8dp"
        android:background="#332B2933" />

    <!-- Bloc contrat -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTRAT"
            android:textColor="#9A95A6"
            android:textSize="11sp"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/w_days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#F4F2F8"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/w_days_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="jours restants"
            android:textColor="#9A95A6"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
